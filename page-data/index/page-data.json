45c57e96c7109f68/0bd8c/safer-world.webp 750w,\n/static/2d185a576e91403f45c57e96c7109f68/47f67/safer-world.webp 1000w,\n/static/2d185a576e91403f45c57e96c7109f68/a71c5/safer-world.webp 1115w","sizes":"(max-width: 500px) 100vw, 500px"}}},"title":"Cloud Security for a safer World","text":"A multi-Cloud Platform for all major Cloud Providers: Amazon Web Services, Microsoft Azure, Google Cloud, Oracle Cloud and IBM Cloud. We handle Cloud Native Security (VMs, Network, Serverless, Databases, Apps), Vulnerability and Threat Management, Cloud Inventory, Cost reduction, Compliance and Secure Cloud Design.\n","cta":{"label":"Access Demo","link":"demo"}},{"image":{"childImageSharp":{"fluid":{"base64":"data:image/png;base64,","aspectRatio":1.358695652173913,"src":"/static/77aadf64265d7c64d659a06e88b95aac/bb15e/control-and-visibility.png","srcSet":"/static/77aadf64265d7c64d659a06e88b95aac/c39b7/control-and-visibility.png 125w,\n/static/77aadf64265d7c64d659a06e88b95aac/a7dc8/control-and-visibility.png 250w,\n/static/77aadf64265d7c64d659a06e88b95aac/bb15e/control-and-visibility.png 500w,\n/static/77aadf64265d7c64d659a06e88b95aac/54539/control-and-visibility.png 750w,\n/static/77aadf64265d7c64d659a06e88b95aac/e04ce/control-and-visibility.png 1000w,\n/static/77aadf64265d7c64d659a06e88b95aac/a4ec3/control-and-visibility.png 2308w","srcWebp":"/static/77aadf64265d7c64d659a06e88b95aac/9f4bf/control-and-visibility.webp","srcSetWebp":"/static/77aadf64265d7c64d659a06e88b95aac/8541d/control-and-visibility.webp 125w,\n/static/77aadf64265d7c64d659a06e88b95aac/23b76/control-and-visibility.webp 250w,\n/static/77aadf64265d7c64d659a06e88b95aac/9f4bf/control-and-visibility.webp 500w,\n/static/77aadf64265d7c64d659a06e88b95aac/0bd8c/control-and-visibility.webp 750w,\n/static/77aadf64265d7c64d659a06e88b95aac/47f67/control-and-visibility.webp 1000w,\n/static/77aadf64265d7c64d659a06e88b95aac/f41e8/control-and-visibility.webp 2308w","sizes":"(max-width: 500px) 100vw, 500px"}}},"title":"Control and Visibility","text":"Most Cloud Providers operate under the Shared Responsibility Model, which puts you in charge of Security in the Cloud. You have the responsibility to protect your biggest asset: your data. Having a single dashboard to visualise and protect your multi-cloud infrastructure is the best way to tackle the advanced persistent threats targeting the Cloud.\n","cta":null},{"image":{"childImageSharp":{"fluid":{"base64":"data:image/png;base64,","aspectRatio":2.358490566037736,"src":"/static/a885d70eae0426b01c14ba0ad007d65a/bb15e/multi-cloud-management.png","srcSet":"/static/a885d70eae0426b01c14ba0ad007d65a/c39b7/multi-cloud-management.png 125w,\n/static/a885d70eae0426b01c14ba0ad007d65a/a7dc8/multi-cloud-management.png 250w,\n/static/a885d70eae0426b01c14ba0ad007d65a/bb15e/multi-cloud-management.png 500w,\n/static/a885d70eae0426b01c14ba0ad007d65a/54539/multi-cloud-management.png 750w,\n/static/a885d70eae0426b01c14ba0ad007d65a/e04ce/multi-cloud-management.png 1000w,\n/static/a885d70eae0426b01c14ba0ad007d65a/2cf84/multi-cloud-management.png 1024w","srcWebp":"/static/a885d70eae0426b01c14ba0ad007d65a/9f4bf/multi-cloud-management.webp","srcSetWebp":"/static/a885d70eae0426b01c14ba0ad007d65a/8541d/multi-cloud-management.webp 125w,\n/static/a885d70eae0426b01c14ba0ad007d65a/23b76/multi-cloud-management.webp 250w,\n/static/a885d70eae0426b01c14ba0ad007d65a/9f4bf/multi-cloud-management.webp 500w,\n/static/a885d70eae0426b01c14ba0ad007d65a/0bd8c/multi-cloud-management.webp 750w,\n/static/a885d70eae0426b01c14ba0ad007d65a/47f67/multi-cloud-management.webp 1000w,\n/static/a885d70eae0426b01c14ba0ad007d65a/b5e5f/multi-cloud-management.webp 1024w","sizes":"(max-width: 500px) 100vw, 500px"}}},"title":"Multi-Cloud Management","text":"Multi-Cloud Platform for all major Cloud Providers: Amazon Web Services, Microsoft Azure, Google Cloud, Oracle Cloud and IBM Cloud. We handle Cloud Native Security (VMs, Network, Serverless, Databases, Apps), Vulnerability and Threat Management, Cloud Inventory, Cost reduction, Compliance and Secure Design.\n","cta":null},{"image":{"childImageSharp":{"fluid":{"base64":"data:image/png;base64,","aspectRatio":1.2755102040816326,"src":"/static/dea196052b48801a0208a223e9898d68/bb15e/compliance-regulatory.png","srcSet":"/static/dea196052b48801a0208a223e9898d68/c39b7/compliance-regulatory.png 125w,\n/static/dea196052b48801a0208a223e9898d68/a7dc8/compliance-regulatory.png 250w,\n/static/dea196052b48801a0208a223e9898d68/bb15e/compliance-regulatory.png 500w,\n/static/dea196052b48801a0208a223e9898d68/54539/compliance-regulatory.png 750w,\n/static/dea196052b48801a0208a223e9898d68/e04ce/compliance-regulatory.png 1000w,\n/static/dea196052b48801a0208a223e9898d68/2cf84/compliance-regulatory.png 1024w","srcWebp":"/static/dea196052b48801a0208a223e9898d68/9f4bf/compliance-regulatory.webp","srcSetWebp":"/static/dea196052b48801a0208a223e9898d68/8541d/compliance-regulatory.webp 125w,\n/static/dea196052b48801a0208a223e9898d68/23b76/compliance-regulatory.webp 250w,\n/static/dea196052b48801a0208a223e9898d68/9f4bf/compliance-regulatory.webp 500w,\n/static/dea196052b48801a0208a223e9898d68/0bd8c/compliance-regulatory.webp 750w,\n/static/dea196052b48801a0208a223e9898d68/47f67/compliance-regulatory.webp 1000w,\n/static/dea196052b48801a0208a223e9898d68/b5e5f/compliance-regulatory.webp 1024w","sizes":"(max-width: 500px) 100vw, 500px"}}},"title":"Compliance & Regulatory","text":"The moment you start using any cloud provider, you must ensure compliance with various regulations and certifications. Each industry is different and can fall under the incidence of sector-specific legislation such as HIPAA for health data in the US or NIST for organizations working with the US government or general standards like CIS or PCI-DSS for payments. Increasingly though, general data protection regulations such as the GDPR in Europe, CCPA in California, LGPD in Brazil etc. have made data protection mandatory by law, with hefty fines applied to those who do not comply with their requirements. We can help you with all of them by automating and generating Compliance Assessments for each of your cloud environments.\n","cta":null},{"image":{"childImageSharp":{"fluid":{"base64":"data:image/png;base64,","aspectRatio":1.9841269841269842,"src":"/static/e656dc80053a066627d2fefba42eabba/bb15e/cloud-native-security.png","srcSet":"/static/e656dc80053a066627d2fefba42eabba/c39b7/cloud-native-security.png 125w,\n/static/e656dc80053a066627d2fefba42eabba/a7dc8/cloud-native-security.png 250w,\n/static/e656dc80053a066627d2fefba42eabba/bb15e/cloud-native-security.png 500w,\n/static/e656dc80053a066627d2fefba42eabba/54539/cloud-native-security.png 750w,\n/static/e656dc80053a066627d2fefba42eabba/e04ce/cloud-native-security.png 1000w,\n/static/e656dc80053a066627d2fefba42eabba/2cf84/cloud-native-security.png 1024w","srcWebp":"/static/e656dc80053a066627d2fefba42eabba/9f4bf/cloud-native-security.webp","srcSetWebp":"/static/e656dc80053a066627d2fefba42eabba/8541d/cloud-native-security.webp 125w,\n/static/e656dc80053a066627d2fefba42eabba/23b76/cloud-native-security.webp 250w,\n/static/e656dc80053a066627d2fefba42eabba/9f4bf/cloud-native-security.webp 500w,\n/static/e656dc80053a066627d2fefba42eabba/0bd8c/cloud-native-security.webp 750w,\n/static/e656dc80053a066627d2fefba42eabba/47f67/cloud-native-security.webp 1000w,\n/static/e656dc80053a066627d2fefba42eabba/b5e5f/cloud-native-security.webp 1024w","sizes":"(max-width: 500px) 100vw, 500px"}}},"title":"Cloud-Native Security","text":"Baked-in Security for modern Cloud Apps, Services and Infrastructures. Kubernetes, Docker images and containers, Terraform, Serverless, Cloud Resources… too many to even remember, let alone manage! We have you covered with a single, agentless tool, so that you don’t have to install and maintain anything. Cyscale Platform was born in the Cloud to protect the Cloud. Make Cyscale your Cloud Native Team today!\n","cta":null},{"image":{"childImageSharp":{"fluid":{"base64":"data:image/png;base64,","aspectRatio":1.6233766233766234,"src":"/static/4b9c39aa07687114b9c4876de2a3ae36/bb15e/cloud-studio-editor.png","srcSet":"/static/4b9c39aa07687114b9c4876de2a3ae36/c39b7/cloud-studio-editor.png 125w,\n/static/4b9c39aa07687114b9c4876de2a3ae36/a7dc8/cloud-studio-editor.png 250w,\n/static/4b9c39aa07687114b9c4876de2a3ae36/bb15e/cloud-studio-editor.png 500w,\n/static/4b9c39aa07687114b9c4876de2a3ae36/54539/cloud-studio-editor.png 750w,\n/static/4b9c39aa07687114b9c4876de2a3ae36/e04ce/cloud-studio-editor.png 1000w,\n/static/4b9c39aa07687114b9c4876de2a3ae36/2cf84/cloud-studio-editor.png 1024w","srcWebp":"/static/4b9c39aa07687114b9c4876de2a3ae36/9f4bf/cloud-studio-editor.webp","srcSetWebp":"/static/4b9c39aa07687114b9c4876de2a3ae36/8541d/cloud-studio-editor.webp 125w,\n/static/4b9c39aa07687114b9c4876de2a3ae36/23b76/cloud-studio-editor.webp 250w,\n/static/4b9c39aa07687114b9c4876de2a3ae36/9f4bf/cloud-studio-editor.webp 500w,\n/static/4b9c39aa07687114b9c4876de2a3ae36/0bd8c/cloud-studio-editor.webp 750w,\n/static/4b9c39aa07687114b9c4876de2a3ae36/47f67/cloud-studio-editor.webp 1000w,\n/static/4b9c39aa07687114b9c4876de2a3ae36/b5e5f/cloud-studio-editor.webp 1024w","sizes":"(max-width: 500px) 100vw, 500px"}}},"title":"Cloud Studio Editor","text":"Meet our state-of-the-art Cloud Studio, a visual tool that helps you design and deploy your cloud infrastructures with security in mind while knowing the costs upfront and ensuring continuous regulatory compliance. No other product out there offers this functionality. Have a Secure Cloud, your way! Without code, scripts and months of cloud training and certifications.\n","cta":null}]}}},"pageContext":{"id":"f6d7d6fc-88a4-57d8-979c-f59b20348f3b"}}}